<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- ── Dev / local: human-readable console output ────────────────────── -->
    <springProfile name="default,dev,test">
        <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{HH:mm:ss.SSS} %-5level [%X{requestId:--}] [%X{transferRef:--}] %logger{36} - %msg%n</pattern>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="STDOUT"/>
        </root>
        <!-- Reduce noise from framework internals in dev -->
        <logger name="org.springframework.security" level="WARN"/>
        <logger name="org.hibernate.SQL" level="WARN"/>
        <logger name="com.zaxxer.hikari" level="WARN"/>
    </springProfile>

    <!-- ── Staging / Prod: structured JSON logging ───────────────────────── -->
    <!-- All MDC fields are included automatically by LogstashEncoder:        -->
    <!--   requestId, transferRef, inquiryRef, outboxEventId, bankCode        -->
    <springProfile name="staging,prod">
        <appender name="STDOUT_JSON" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <throwableConverter class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">
                    <maxDepthPerCause>20</maxDepthPerCause>
                    <shortenedClassNameLength>35</shortenedClassNameLength>
                    <rootCauseFirst>true</rootCauseFirst>
                </throwableConverter>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="STDOUT_JSON"/>
        </root>
    </springProfile>

</configuration>
