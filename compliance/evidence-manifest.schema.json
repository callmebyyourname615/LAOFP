{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://switching.example/schemas/go-live-evidence-manifest-v1.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion", "generatedAt", "releaseDigest", "commitSha",
    "evidenceBase", "evidence", "approvals", "status"
  ],
  "properties": {
    "schemaVersion": {"const": 1},
    "generatedAt": {"type": "string", "format": "date-time"},
    "releaseDigest": {"type": "string", "pattern": "^sha256:[0-9a-fA-F]{64}$"},
    "commitSha": {"type": "string", "pattern": "^[0-9a-fA-F]{40}$"},
    "evidenceBase": {"type": "string", "minLength": 1},
    "status": {"enum": ["DRAFT_NOT_APPROVED", "APPROVED", "REJECTED"]},
    "evidence": {
      "type": "array",
      "minItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "path", "sha256", "bytes"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "path": {"type": "string", "minLength": 1, "not": {"pattern": "(^/|(^|/)\\.\\.(/|$))"}},
          "sha256": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"},
          "bytes": {"type": "integer", "minimum": 0}
        }
      }
    },
    "approvals": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "approver", "approvedAt", "decision"],
        "properties": {
          "role": {"enum": ["engineering", "security", "operations", "business", "compliance"]},
          "approver": {"type": "string", "minLength": 1},
          "approvedAt": {"type": "string", "format": "date-time"},
          "decision": {"enum": ["APPROVED", "REJECTED"]},
          "comment": {"type": "string"}
        }
      }
    }
  }
}
