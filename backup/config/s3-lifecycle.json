{
  "Rules": [
    {
      "ID": "ExpireSwitchingBaseBackups",
      "Status": "Enabled",
      "Filter": { "Prefix": "switching/base/" },
      "Expiration": { "Days": 35 },
      "NoncurrentVersionExpiration": { "NoncurrentDays": 90 }
    },
    {
      "ID": "ExpireSwitchingWalAfterRecoveryWindow",
      "Status": "Enabled",
      "Filter": { "Prefix": "switching/wal/" },
      "Expiration": { "Days": 35 },
      "NoncurrentVersionExpiration": { "NoncurrentDays": 90 }
    },
    {
      "ID": "AbortIncompleteMultipartUploads",
      "Status": "Enabled",
      "Filter": { "Prefix": "switching/" },
      "AbortIncompleteMultipartUpload": { "DaysAfterInitiation": 1 }
    }
  ]
}
