# PostgreSQL replication connection. Use a dedicated REPLICATION LOGIN role.
PGHOST=postgres.example.internal
PGPORT=5432
PGDATABASE=switching_db
PGUSER=switching_backup
PGPASSWORD=REPLACE_WITH_VAULT_VALUE
PGSSLMODE=verify-full
PGSSLROOTCERT=/var/run/secrets/trust/postgres-ca.crt

# Primary S3-compatible repository.
S3_ENDPOINT=https://s3.primary.example
S3_REGION=ap-southeast-1
S3_BUCKET=switching-prod-backups
S3_PREFIX=switching
AWS_ACCESS_KEY_ID=REPLACE_WITH_VAULT_VALUE
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_VAULT_VALUE
S3_SERVER_SIDE_ENCRYPTION=AES256

# Client-side encryption. Commit only the public age recipient.
BACKUP_AGE_RECIPIENT=age1REPLACE_WITH_PUBLIC_RECIPIENT
BACKUP_AGE_IDENTITY_FILE=/var/run/secrets/backup/age-identity.txt

# Mandatory secondary/off-site copy in production.
SECONDARY_S3_ENABLED=true
SECONDARY_S3_ENDPOINT=https://s3.secondary.example
SECONDARY_S3_REGION=ap-southeast-2
SECONDARY_S3_BUCKET=switching-prod-backups-dr
SECONDARY_AWS_ACCESS_KEY_ID=REPLACE_WITH_VAULT_VALUE
SECONDARY_AWS_SECRET_ACCESS_KEY=REPLACE_WITH_VAULT_VALUE

WAL_REPLICATION_SLOT=switching_backup_slot
PUSHGATEWAY_URL=http://prometheus-pushgateway.monitoring.svc:9091
RESTORE_DRILL_RTO_TARGET_SECONDS=3600
