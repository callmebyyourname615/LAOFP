# Production template. Values here are placeholders: replace every value before use.
# Prefer injecting these from a secrets manager or Kubernetes Secret/ConfigMap.

SPRING_PROFILES_ACTIVE=prod

# Database. Use managed PostgreSQL or hardened cluster endpoints with TLS.
DB_URL=jdbc:postgresql://REPLACE_WITH_PROD_DB_HOST:5432/switching_db?sslmode=require
DB_USERNAME=switching_app
DB_PASSWORD=REPLACE_ME
FLYWAY_URL=jdbc:postgresql://REPLACE_WITH_PROD_DB_HOST:5432/switching_db?sslmode=require
FLYWAY_USERNAME=switching_flyway
FLYWAY_PASSWORD=REPLACE_ME

# Kafka/Redpanda production connectivity.
SPRING_KAFKA_BOOTSTRAP_SERVERS=REPLACE_WITH_PROD_KAFKA_1:9093,REPLACE_WITH_PROD_KAFKA_2:9093,REPLACE_WITH_PROD_KAFKA_3:9093
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=SCRAM-SHA-512
KAFKA_SASL_JAAS_CONFIG=org.apache.kafka.common.security.scram.ScramLoginModule required username="REPLACE_WITH_KAFKA_USERNAME" password="REPLACE_WITH_KAFKA_PASSWORD";
KAFKA_SSL_TRUSTSTORE_LOCATION=
KAFKA_SSL_TRUSTSTORE_PASSWORD=
KAFKA_SSL_TRUSTSTORE_TYPE=PKCS12
KAFKA_SSL_KEYSTORE_LOCATION=
KAFKA_SSL_KEYSTORE_PASSWORD=
KAFKA_SSL_KEYSTORE_TYPE=PKCS12
OUTBOX_QUEUE_ENABLED=true
OUTBOX_QUEUE_TOPIC=switching.outbox.dispatch
OUTBOX_QUEUE_GROUP_ID=switching-outbox-dispatcher

# Payment-network/external dependencies.
ACCOUNT_LOOKUP_BASE_URL=https://REPLACE_WITH_ACCOUNT_LOOKUP_GATEWAY
BOL_RTGS_URL=https://REPLACE_WITH_BOL_RTGS_HOST/rtgs/pacs009
RTGS_CALLBACK_IP_WHITELIST=REPLACE_WITH_BOL_CALLBACK_CIDRS
BOL_FIU_URL=https://REPLACE_WITH_BOL_FIU_HOST/fiu
BOL_FIU_API_KEY=REPLACE_ME
PROMPTPAY_API_URL=https://REPLACE_WITH_PROMPTPAY_GATEWAY/promptpay
CNAPS_API_URL=https://REPLACE_WITH_CNAPS_GATEWAY/cnaps
NAPAS_API_URL=https://REPLACE_WITH_NAPAS_GATEWAY/napas
SWIFT_API_URL=https://REPLACE_WITH_SWIFT_GATEWAY/swift

# Archive/object storage.
ARCHIVE_DB_URL=jdbc:postgresql://REPLACE_WITH_ARCHIVE_DB_HOST:5432/switching_archive?sslmode=require
ARCHIVE_DB_USERNAME=switching_archive
ARCHIVE_DB_PASSWORD=REPLACE_ME
OBJECT_STORAGE_ENDPOINT=https://REPLACE_WITH_OBJECT_STORAGE_HOST
OBJECT_STORAGE_BUCKET=switching-archive
OBJECT_STORAGE_ACCESS_KEY=REPLACE_ME
OBJECT_STORAGE_SECRET_KEY=REPLACE_ME

# Security. Generate strong values from a secrets manager.
MESSAGE_CRYPTO_KEY_BASE64=REPLACE_ME
OAUTH_JWT_SECRET=REPLACE_ME
SECURITY_OAUTH_ENABLED=true
SECURITY_MTLS_ENABLED=true
SECURITY_SIGNING_ENABLED=true
MTLS_CERT_HEADER=ssl-client-cert
SIGNING_TIMESTAMP_TOLERANCE=30
RATE_LIMIT_RPM=60

# Prod defaults.
JSON_INITIATION_ENABLED=false
MANAGEMENT_PORT=9090

# Webhook signing-secret envelope encryption (Vault Transit).
WEBHOOK_ENDPOINT_POLICY_ENABLED=true
WEBHOOK_EGRESS_PROXY_ENABLED=true
WEBHOOK_EGRESS_PROXY_HOST=
WEBHOOK_EGRESS_PROXY_PORT=3128
WEBHOOK_REQUIRE_HTTPS=true
WEBHOOK_REQUIRE_ALLOWLIST=true
WEBHOOK_ALLOW_PRIVATE_ADDRESSES=false
WEBHOOK_ALLOWED_PORTS=443
WEBHOOK_ALLOWED_HOSTS=hooks.bank-a.example,hooks.bank-b.example
WEBHOOK_DNS_TIMEOUT_MS=3000
WEBHOOK_ENCRYPTION_PROVIDER=vault-transit
VAULT_ADDR=https://REPLACE_WITH_VAULT_HOST
VAULT_TOKEN=REPLACE_ME
VAULT_NAMESPACE=
WEBHOOK_VAULT_TRANSIT_MOUNT=transit
WEBHOOK_VAULT_TRANSIT_KEY=switching-webhook
WEBHOOK_VAULT_CONNECT_TIMEOUT=3s
WEBHOOK_VAULT_REQUEST_TIMEOUT=5s
WEBHOOK_SECRET_ROTATION_GRACE_MINUTES=60
WEBHOOK_SECRET_ROTATION_MAX_GRACE_MINUTES=10080

# Event schema compatibility — keep false except during an approved migration window
OUTBOX_SCHEMA_ALLOW_LEGACY=false
