# Production contract template. This file contains no usable secrets.
# Render it from Vault/External Secrets; never commit a populated copy.

SPRING_PROFILES_ACTIVE=prod
OBSERVABILITY_ENVIRONMENT=production
OPERATIONAL_METRICS_ENABLED=true
OPERATIONAL_METRICS_REFRESH=PT30S
JSON_INITIATION_ENABLED=false
OUTBOX_SCHEMA_ALLOW_LEGACY=false
SECURITY_OAUTH_ENABLED=true
SECURITY_MTLS_ENABLED=true
SECURITY_SIGNING_ENABLED=true

DB_URL=jdbc:postgresql://__REQUIRED_PROD_DB_HOST__:5432/switching_db?sslmode=verify-full&sslrootcert=/etc/switching/tls/postgres-ca.crt
DB_USERNAME=__REQUIRED_DB_APP_USERNAME__
DB_PASSWORD=__REQUIRED_DB_APP_PASSWORD__
FLYWAY_URL=jdbc:postgresql://__REQUIRED_PROD_DB_HOST__:5432/switching_db?sslmode=verify-full&sslrootcert=/etc/switching/tls/postgres-ca.crt
FLYWAY_USERNAME=__REQUIRED_FLYWAY_USERNAME__
FLYWAY_PASSWORD=__REQUIRED_FLYWAY_PASSWORD__

READ_REPLICA_ENABLED=true
READ_REPLICA_URL=jdbc:postgresql://__REQUIRED_PROD_REPLICA_DB_HOST__:5432/switching_db?sslmode=verify-full&sslrootcert=/etc/switching/tls/postgres-ca.crt
READ_REPLICA_USERNAME=__REQUIRED_READ_REPLICA_USERNAME__
READ_REPLICA_PASSWORD=__REQUIRED_READ_REPLICA_PASSWORD__
READ_REPLICA_MAX_POOL_SIZE=20
READ_REPLICA_MIN_IDLE=2

TRACING_ENABLED=true
TRACING_SAMPLING_PROBABILITY=0.10
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=https://__REQUIRED_OTLP_COLLECTOR_HOST__/v1/traces
SQL_INSPECTION_ENABLED=false
SQL_INSPECTION_QUERY_WARNING_THRESHOLD=50
SQL_INSPECTION_REPEATED_STATEMENT_THRESHOLD=10

KAFKA_OBSERVATION_ENABLED=true
SPRING_KAFKA_BOOTSTRAP_SERVERS=__REQUIRED_KAFKA_BROKERS__
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SSL_ENDPOINT_IDENTIFICATION_ALGORITHM=https
KAFKA_SASL_MECHANISM=SCRAM-SHA-512
KAFKA_SASL_JAAS_CONFIG=__REQUIRED_KAFKA_JAAS_SECRET__
KAFKA_SSL_TRUSTSTORE_LOCATION=/etc/switching/tls/kafka-truststore.p12
KAFKA_SSL_TRUSTSTORE_PASSWORD=__REQUIRED_KAFKA_TRUSTSTORE_PASSWORD__
KAFKA_SSL_KEYSTORE_LOCATION=/etc/switching/tls/kafka-keystore.p12
KAFKA_SSL_KEYSTORE_PASSWORD=__REQUIRED_KAFKA_KEYSTORE_PASSWORD__
KAFKA_SSL_TRUSTSTORE_TYPE=PKCS12
KAFKA_SSL_KEYSTORE_TYPE=PKCS12
OUTBOX_QUEUE_ENABLED=true
OUTBOX_QUEUE_TOPIC=switching.outbox.dispatch
OUTBOX_QUEUE_GROUP_ID=switching-outbox-dispatcher

MESSAGE_CRYPTO_KEY_BASE64=__REQUIRED_MESSAGE_CRYPTO_KEY_BASE64__
OAUTH_JWT_SECRET=__REQUIRED_OAUTH_JWT_SECRET__
SMOS_ENABLED=true
SMOS_MFA_REQUIRED=true
SMOS_PASSWORD_MINIMUM_LENGTH=14
SMOS_DASHBOARD_QUERY_TIMEOUT_MS=3000
SMOS_JWT_SECRET=__REQUIRED_SMOS_JWT_SECRET__
SMOS_BOOTSTRAP_ENABLED=false

ACCOUNT_LOOKUP_BASE_URL=https://__REQUIRED_ACCOUNT_LOOKUP_HOST__
BOL_RTGS_URL=https://__REQUIRED_BOL_RTGS_HOST__/rtgs/pacs009
RTGS_CALLBACK_IP_WHITELIST=__REQUIRED_BOL_CALLBACK_CIDRS__
BOL_FIU_URL=https://__REQUIRED_BOL_FIU_HOST__/fiu
BOL_FIU_API_KEY=__REQUIRED_BOL_FIU_API_KEY__
AML_BOL_SANCTIONS_URL=https://__REQUIRED_BOL_SANCTIONS_HOST__/sanctions
AML_BOL_SANCTIONS_API_KEY=__REQUIRED_BOL_SANCTIONS_API_KEY__
PROMPTPAY_API_URL=https://__REQUIRED_PROMPTPAY_HOST__/promptpay
CNAPS_API_URL=https://__REQUIRED_CNAPS_HOST__/cnaps
NAPAS_API_URL=https://__REQUIRED_NAPAS_HOST__/napas
SWIFT_API_URL=https://__REQUIRED_SWIFT_HOST__/swift

ARCHIVE_DB_URL=jdbc:postgresql://__REQUIRED_ARCHIVE_DB_HOST__:5432/switching_archive?sslmode=verify-full&sslrootcert=/etc/switching/tls/postgres-ca.crt
ARCHIVE_DB_USERNAME=__REQUIRED_ARCHIVE_DB_USERNAME__
ARCHIVE_DB_PASSWORD=__REQUIRED_ARCHIVE_DB_PASSWORD__
OBJECT_STORAGE_ENDPOINT=https://__REQUIRED_OBJECT_STORAGE_HOST__
OBJECT_STORAGE_BUCKET=switching-archive
OBJECT_STORAGE_ACCESS_KEY=__REQUIRED_OBJECT_STORAGE_ACCESS_KEY__
OBJECT_STORAGE_SECRET_KEY=__REQUIRED_OBJECT_STORAGE_SECRET_KEY__

WEBHOOK_ENDPOINT_POLICY_ENABLED=true
WEBHOOK_EGRESS_PROXY_ENABLED=true
WEBHOOK_EGRESS_PROXY_HOST=__REQUIRED_WEBHOOK_EGRESS_PROXY_HOST__
WEBHOOK_EGRESS_PROXY_PORT=3128
WEBHOOK_REQUIRE_HTTPS=true
WEBHOOK_REQUIRE_ALLOWLIST=true
WEBHOOK_ALLOW_PRIVATE_ADDRESSES=false
WEBHOOK_ALLOWED_PORTS=443
WEBHOOK_ALLOWED_HOSTS=__REQUIRED_WEBHOOK_ALLOWED_HOSTS__
WEBHOOK_DNS_TIMEOUT_MS=3000
WEBHOOK_ENCRYPTION_PROVIDER=vault-transit
VAULT_ADDR=https://__REQUIRED_VAULT_HOST__
VAULT_NAMESPACE=__REQUIRED_VAULT_NAMESPACE__
WEBHOOK_VAULT_AUTH_METHOD=kubernetes
WEBHOOK_VAULT_KUBERNETES_ROLE=__REQUIRED_VAULT_KUBERNETES_ROLE__
WEBHOOK_VAULT_SERVICE_ACCOUNT_TOKEN_FILE=/var/run/secrets/kubernetes.io/serviceaccount/token
WEBHOOK_VAULT_TRANSIT_MOUNT=transit
WEBHOOK_VAULT_TRANSIT_KEY=switching-webhook
WEBHOOK_VAULT_CONNECT_TIMEOUT=3s
WEBHOOK_VAULT_REQUEST_TIMEOUT=5s
WEBHOOK_SECRET_ROTATION_GRACE_MINUTES=60
WEBHOOK_SECRET_ROTATION_MAX_GRACE_MINUTES=10080

MANAGEMENT_PORT=9090
RATE_LIMIT_RPM=60

PROMOTION_BUDGET_EXPIRY_SCAN_MS=60000
