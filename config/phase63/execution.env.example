# Phase 63 runtime configuration — copy to config/phase63/execution.env.
# Never commit the populated file. Keep secrets in Vault or runner secret storage.

TARGET_ENVIRONMENT=uat
PHASE63_EXECUTE_RUNTIME=false
CONFIRM_UAT_DRILLS=no
PHASE63_PLATFORM=kubernetes
PHASE63_NAMESPACE=switching
PHASE63_COMMAND_TIMEOUT_SECONDS=3600

# Phase 63A / Phase 61C
UAT_ENV_FILE=/secure/path/uat.env
UAT_BASE_URL=https://switching-uat.example.internal

# Phase 63C — signed Phase 61 supply-chain attestation
PHASE63_SUPPLY_CHAIN_ATTESTATION=/secure/evidence/phase61-supply-chain-attestation.json

# Phase 63D — capacity execution. API_KEY must come from secret storage.
BASE_URL=https://switching-uat.example.internal
API_KEY=
PHASE63_CAPACITY_ATTESTATION=/secure/evidence/phase61-capacity-attestation.json
PERFORMANCE_NAMESPACE=switching
PROMETHEUS_URL=https://prometheus-uat.example.internal

# Phase 63E — explicit topology-specific command hooks. These commands must write
# their own immutable IDs/timestamps to stdout; stdout becomes evidence.
PHASE63_BACKUP_PITR_ATTESTATION=/secure/evidence/phase63-backup-pitr-attestation.json
PHASE63_FULL_BACKUP_COMMAND=backup/bin/full-backup.sh
PHASE63_VERIFY_BACKUP_COMMAND=backup/bin/verify-backup.sh
PHASE63_PITR_COMMAND=backup/bin/restore-drill.sh

# Phase 63F — DR. Database credentials must be injected, never stored here.
DB_URL=
DB_USERNAME=
DB_PASSWORD=
PHASE63_DR_ATTESTATION=/secure/evidence/phase63-dr-attestation.json
PHASE63_POSTGRES_FAILOVER_COMMAND=
PHASE63_POSTGRES_FAILBACK_COMMAND=
PHASE63_INCLUDE_REGION_FAILOVER=false

# Phase 63G — Alertmanager test delivery.
ALERTMANAGER_URL=https://alertmanager-uat.example.internal
ALERT_EXPECTED_RECEIVER=switching-uat-oncall
ALERTMANAGER_BEARER_TOKEN=
PHASE63_ALERT_ATTESTATION=/secure/evidence/phase63-alert-attestation.json

# Phase 63H — optional signed runtime suite command.
PHASE63_SMOS_RUNTIME_COMMAND=./mvnw -q -Dtest='Smos*IntegrationTest,*Security*IntegrationTest' test

# Phase 63I — settlement and sanctions evidence.
PHASE63_SETTLEMENT_ATTESTATION=/secure/evidence/phase61-settlement-attestation.json
PHASE63_SANCTIONS_ATTESTATION=/secure/evidence/phase63-sanctions-attestation.json
PHASE63_SANCTIONS_SYNC_COMMAND=

# Phase 63J — signed final UAT entry approval.
PHASE63_UAT_ENTRY_ATTESTATION=/secure/evidence/phase63-uat-entry-attestation.json
