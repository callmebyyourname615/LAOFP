{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifacts": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string"
          },
          "sha256": {
            "pattern": "^[0-9a-f]{64}$"
          },
          "size": {
            "minimum": 0,
            "type": "integer"
          }
        },
        "required": [
          "path",
          "sha256",
          "size"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "attestationApproved": {
      "type": "boolean"
    },
    "attestationCommitMatches": {
      "type": "boolean"
    },
    "decision": {
      "enum": [
        "PREPARED",
        "BLOCKED",
        "NO_GO",
        "GO"
      ]
    },
    "generatedAt": {
      "format": "date-time",
      "type": "string"
    },
    "gitCommit": {
      "type": "string"
    },
    "missingPhases": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "mode": {
      "enum": [
        "preflight",
        "full"
      ]
    },
    "phase": {
      "const": "72J"
    },
    "phaseStatuses": {
      "type": "object"
    },
    "schemaVersion": {
      "const": 1
    },
    "syntheticEvidence": {
      "type": "boolean"
    }
  },
  "required": [
    "schemaVersion",
    "phase",
    "decision",
    "mode",
    "generatedAt",
    "gitCommit",
    "phaseStatuses",
    "artifacts"
  ],
  "title": "Phase 72 evidence manifest",
  "type": "object"
}
