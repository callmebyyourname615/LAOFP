{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "actions": {
      "additionalProperties": false,
      "properties": {
        "ciCachesInvalidated": {
          "const": true
        },
        "credentialsGenerated": {
          "const": true
        },
        "forcePushed": {
          "const": true
        },
        "historyPurged": {
          "const": true
        },
        "leakScanClean": {
          "const": true
        },
        "repositoryFrozen": {
          "const": true
        },
        "serviceTokensRotated": {
          "const": true
        },
        "storedInVault": {
          "const": true
        },
        "teamRecloned": {
          "const": true
        }
      },
      "required": [
        "credentialsGenerated",
        "storedInVault",
        "repositoryFrozen",
        "historyPurged",
        "forcePushed",
        "ciCachesInvalidated",
        "serviceTokensRotated",
        "teamRecloned",
        "leakScanClean"
      ],
      "type": "object"
    },
    "approvedAt": {
      "format": "date-time",
      "type": "string"
    },
    "approvers": {
      "additionalProperties": false,
      "properties": {
        "repoCoordinator": {
          "minLength": 2,
          "type": "string"
        },
        "secOps": {
          "minLength": 2,
          "type": "string"
        }
      },
      "required": [
        "secOps",
        "repoCoordinator"
      ],
      "type": "object"
    },
    "gitCommit": {
      "type": "string"
    },
    "schemaVersion": {
      "const": 1
    }
  },
  "required": [
    "schemaVersion",
    "gitCommit",
    "actions",
    "approvers",
    "approvedAt"
  ],
  "title": "Secret rotation ceremony attestation",
  "type": "object"
}
