{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "approval": {
      "required": [
        "present",
        "valid",
        "sha256"
      ],
      "type": "object"
    },
    "artifacts": {
      "type": "array"
    },
    "decision": {
      "enum": [
        "PREPARED",
        "CERTIFIED",
        "BLOCKED"
      ]
    },
    "generatedAt": {
      "type": "string"
    },
    "gitCommit": {
      "type": "string"
    },
    "phases": {
      "maxItems": 9,
      "minItems": 9,
      "type": "array"
    },
    "runId": {
      "minLength": 1,
      "type": "string"
    },
    "schemaVersion": {
      "const": 1
    }
  },
  "required": [
    "schemaVersion",
    "generatedAt",
    "runId",
    "gitCommit",
    "phases",
    "artifacts",
    "approval",
    "decision"
  ],
  "type": "object"
}
