{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "generatedAt": {
      "format": "date-time",
      "type": "string"
    },
    "rtoMinutes": {
      "minimum": 0,
      "type": "number"
    },
    "schemaVersion": {
      "const": 1
    },
    "status": {
      "enum": [
        "PASS",
        "FAIL"
      ]
    }
  },
  "required": [
    "schemaVersion",
    "generatedAt",
    "status"
  ],
  "type": "object"
}
