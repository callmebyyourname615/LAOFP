{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Phase 64 Phase 54 Entry Decision",
  "type": "object",
  "required": ["schemaVersion", "decision", "release", "phases", "sourceEvidence", "errors"],
  "properties": {
    "schemaVersion": {"const": 1},
    "decision": {"enum": ["APPROVE_PHASE54_ENTRY", "BLOCK_PHASE54_ENTRY"]},
    "release": {
      "type": "object",
      "required": ["reference", "gitCommit", "applicationImageDigest", "migrationImageDigest"]
    },
    "phases": {"type": "object", "minProperties": 8},
    "sourceEvidence": {"type": "object"},
    "errors": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
