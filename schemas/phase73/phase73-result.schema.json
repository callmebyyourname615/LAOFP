{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://switching.internal/schemas/phase73/phase73-result.schema.json",
  "title": "Phase 73 Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "phase", "name", "status", "exitCode", "startedAt", "finishedAt", "runId", "targetEnvironment", "gitCommit", "checks", "artifacts"],
  "properties": {
    "schemaVersion": {"const": 1},
    "phase": {"pattern": "^73[A-J]$"},
    "name": {"type": "string", "minLength": 3},
    "status": {"enum": ["PASS", "FAIL", "PREPARED", "SKIPPED"]},
    "exitCode": {"type": "integer"},
    "message": {"type": "string"},
    "startedAt": {"type": "string", "format": "date-time"},
    "finishedAt": {"type": "string", "format": "date-time"},
    "runId": {"type": "string", "minLength": 1},
    "targetEnvironment": {"enum": ["uat", "preflight"]},
    "gitCommit": {"type": "string", "minLength": 7},
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "detail"],
        "properties": {
          "id": {"type": "string"},
          "status": {"enum": ["PASS", "FAIL", "PREPARED", "SKIPPED"]},
          "detail": {"type": "string"}
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sizeBytes", "sha256"],
        "properties": {
          "path": {"type": "string"},
          "sizeBytes": {"type": "integer", "minimum": 0},
          "sha256": {"pattern": "^[0-9a-f]{64}$"}
        }
      }
    }
  }
}
