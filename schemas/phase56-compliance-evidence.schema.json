{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifacts": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string"
          },
          "sha256": {
            "pattern": "^[a-f0-9]{64}$"
          },
          "sizeBytes": {
            "minimum": 0,
            "type": "integer"
          }
        },
        "required": [
          "path",
          "sha256",
          "sizeBytes"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "controls": {
      "type": "array"
    },
    "generatedAt": {
      "format": "date-time",
      "type": "string"
    },
    "release": {
      "type": "object"
    },
    "schemaVersion": {
      "const": 1
    }
  },
  "required": [
    "schemaVersion",
    "generatedAt",
    "release",
    "artifacts",
    "controls"
  ],
  "type": "object"
}
