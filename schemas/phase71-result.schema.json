{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://switching.example/schemas/phase71-result.schema.json",
  "title": "Phase 71 Result",
  "type": "object",
  "required": ["schemaVersion", "phase", "name", "status", "exitCode", "message", "startedAt", "finishedAt", "commit"],
  "properties": {
    "schemaVersion": {"const": 1},
    "phase": {"pattern": "^71[A-J]$"},
    "name": {"type": "string", "minLength": 1},
    "status": {"enum": ["PASS", "PREPARED", "BLOCKED", "FAIL"]},
    "exitCode": {"type": "integer"},
    "message": {"type": "string"},
    "startedAt": {"type": "string", "format": "date-time"},
    "finishedAt": {"type": "string", "format": "date-time"},
    "commit": {"type": "string"},
    "applicationImageDigest": {"type": "string"},
    "migrationImageDigest": {"type": "string"},
    "targetEnvironment": {"type": "string"}
  },
  "additionalProperties": false
}
