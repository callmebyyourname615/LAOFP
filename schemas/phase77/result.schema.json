{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "phase",
    "status",
    "message",
    "synthetic",
    "git_commit"
  ],
  "properties": {
    "status": {
      "enum": [
        "PASS",
        "FAIL",
        "BLOCKED",
        "PREPARED"
      ]
    }
  },
  "additionalProperties": true
}
