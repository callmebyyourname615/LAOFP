{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "score",
    "color",
    "release_allowed",
    "dimensions"
  ],
  "properties": {
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "color": {
      "enum": [
        "GREEN",
        "AMBER",
        "RED"
      ]
    }
  },
  "additionalProperties": true
}
