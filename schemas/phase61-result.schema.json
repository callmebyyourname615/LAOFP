{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Phase 61 Result",
  "type": "object",
  "required": ["schemaVersion", "phase", "status", "exitCode", "gitCommit", "targetEnvironment", "artifacts"],
  "properties": {
    "schemaVersion": {"const": 1},
    "phase": {"pattern": "^61[A-J]$"},
    "status": {"enum": ["PASS", "FAIL", "PREPARED", "SKIPPED"]},
    "exitCode": {"type": "integer"},
    "gitCommit": {"type": "string"},
    "targetEnvironment": {"enum": ["repository", "uat"]},
    "artifacts": {"type": "array"}
  },
  "additionalProperties": true
}
