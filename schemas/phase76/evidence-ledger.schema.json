{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "entry_count",
    "tail_hash",
    "entries"
  ],
  "properties": {
    "entry_count": {
      "type": "integer",
      "minimum": 0
    },
    "tail_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "entries": {
      "type": "array"
    }
  },
  "additionalProperties": true
}
