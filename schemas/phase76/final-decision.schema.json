{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "decision",
    "git_commit",
    "blockers",
    "synthetic"
  ],
  "properties": {
    "decision": {
      "enum": [
        "PREPARED",
        "BLOCKED",
        "NO_GO",
        "GO",
        "CANARY_GO",
        "HOLD",
        "ROLLBACK"
      ]
    },
    "synthetic": {
      "type": "boolean"
    }
  },
  "additionalProperties": true
}
