{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://switching.example/schemas/phase67-cutover-decision.schema.json",
  "title": "Phase 67 Cutover Decision",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "generatedAt", "stage", "decision", "release", "signals", "reasons"],
  "properties": {
    "schemaVersion": {"const": 1},
    "generatedAt": {"type": "string", "format": "date-time"},
    "stage": {"type": "string"},
    "decision": {"enum": ["CONTINUE", "HOLD", "ROLLBACK_REQUIRED"]},
    "release": {"type": "object"},
    "signals": {"type": "object", "additionalProperties": {"type": ["boolean", "number", "string", "null"]}},
    "reasons": {"type": "array", "items": {"type": "string"}}
  }
}
