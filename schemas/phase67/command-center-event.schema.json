{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://switching.example/schemas/phase67-command-center-event.schema.json",
  "title": "Phase 67 Command Center Event",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "sequence", "eventId", "recordedAt", "eventType", "actor", "message", "releaseReference", "previousHash", "eventHash"],
  "properties": {
    "schemaVersion": {"const": 1},
    "sequence": {"type": "integer", "minimum": 1},
    "eventId": {"type": "string", "minLength": 8},
    "recordedAt": {"type": "string", "format": "date-time"},
    "eventType": {"type": "string"},
    "actor": {"type": "string", "minLength": 2},
    "message": {"type": "string", "minLength": 1},
    "releaseReference": {"type": "string", "minLength": 3},
    "previousHash": {"pattern": "^(GENESIS|[a-f0-9]{64})$"},
    "eventHash": {"pattern": "^[a-f0-9]{64}$"}
  }
}
