# Local development template. Copy to .env for Docker Compose/dev only.
# Do not use this file as production configuration.

SPRING_PROFILES_ACTIVE=dev

# Local Docker Compose database users.
POSTGRES_USER=switching
POSTGRES_PASSWORD=switching_postgres_password_change_me
DB_APP_PASSWORD=switching_app_password_change_me
FLYWAY_PASSWORD=switching_flyway_password_change_me
REPLICATION_USER=switching_replicator
REPLICATION_PASSWORD=switching_replicator_password_change_me

# Read-routing is safe to enable only when this endpoint is a PostgreSQL standby.
SWITCHING_READ_REPLICA_ENABLED=true
READ_REPLICA_DB_URL=jdbc:postgresql://localhost:5435/switching_db
READ_REPLICA_DB_USERNAME=switching_app
READ_REPLICA_DB_PASSWORD=switching_app_password_change_me

# Local archive DB/object storage.
ARCHIVE_POSTGRES_USER=switching_archive
ARCHIVE_POSTGRES_PASSWORD=switching_archive_postgres_password_change_me
MINIO_ROOT_USER=switching_minio
MINIO_ROOT_PASSWORD=switching_minio_password_change_me

# Generate a real local value with:
#   openssl rand -base64 32
MESSAGE_CRYPTO_KEY_BASE64=

# Local Kafka/Redpanda.
SPRING_KAFKA_BOOTSTRAP_SERVERS=redpanda:9092
OUTBOX_QUEUE_ENABLED=true
OUTBOX_QUEUE_TOPIC=switching.outbox.dispatch
OUTBOX_QUEUE_GROUP_ID=switching-outbox-dispatcher

# Local security posture.
JSON_INITIATION_ENABLED=true
SECURITY_OAUTH_ENABLED=false
SECURITY_MTLS_ENABLED=false
SECURITY_SIGNING_ENABLED=false
RATE_LIMIT_RPM=100

# Local-only webhook encryption. Generate a random 32-byte Base64 key.
WEBHOOK_ENDPOINT_POLICY_ENABLED=true
WEBHOOK_EGRESS_PROXY_ENABLED=false
WEBHOOK_EGRESS_PROXY_HOST=
WEBHOOK_EGRESS_PROXY_PORT=3128
WEBHOOK_REQUIRE_HTTPS=true
WEBHOOK_REQUIRE_ALLOWLIST=false
WEBHOOK_ALLOW_PRIVATE_ADDRESSES=false
WEBHOOK_ALLOWED_PORTS=443
WEBHOOK_ALLOWED_HOSTS=
WEBHOOK_DNS_TIMEOUT_MS=3000
WEBHOOK_ENCRYPTION_PROVIDER=local
WEBHOOK_LOCAL_MASTER_KEY_BASE64=
WEBHOOK_SECRET_ROTATION_GRACE_MINUTES=60

# Phase 8 — backup/PITR. Generate an age key pair with `age-keygen` and put only
# the public recipient here. Store the private identity outside the repository.
BACKUP_AGE_RECIPIENT=
BACKUP_AGE_IDENTITY_FILE_HOST=./backup/secrets/age-identity.txt

# Event schema compatibility — keep false except during an approved migration window
OUTBOX_SCHEMA_ALLOW_LEGACY=false
